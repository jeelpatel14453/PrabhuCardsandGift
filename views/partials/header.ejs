<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="<%= typeof description !== 'undefined' ? description : 'Prabhu Cards & Gifts — your neighborhood destination in Manorville, NY for greeting cards, trading cards, gifts, balloons, premium cigars, and more.' %>" />
    <meta name="theme-color" content="#dc2626" />
    <title><%= typeof title !== 'undefined' ? title : 'Prabhu Cards & Gifts | Manorville, NY' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ['"DM Sans"', 'system-ui', 'sans-serif'],
              display: ['"Plus Jakarta Sans"', 'system-ui', 'sans-serif'],
            },
            colors: {
              brand: { red: '#dc2626', blue: '#2563eb', orange: '#ea580c' },
            },
          },
        },
      };
    </script>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="font-sans text-slate-800 bg-white antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-white focus:rounded-lg focus:shadow-lg focus:text-brand-red">
      Skip to main content
    </a>

    <header id="site-header" class="fixed top-0 left-0 right-0 z-50" role="banner">
      <nav class="container mx-auto px-4 sm:px-6 lg:px-8" aria-label="Primary navigation">
        <div class="mt-3 mb-3 flex items-center justify-between rounded-2xl bg-white/90 backdrop-blur-md px-4 py-3 shadow-sm border border-slate-100">
          <a href="/" class="flex items-center gap-2 group">
            <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-red-500 via-blue-500 to-orange-500 text-white font-display font-bold text-lg shadow-md group-hover:scale-105 transition-transform">P</span>
            <span class="font-display font-bold text-slate-900 text-lg hidden sm:block">Prabhu Cards & Gifts</span>
          </a>
          <ul class="hidden lg:flex items-center gap-1">
            <li>
              <a href="/" class="px-3 py-2 rounded-lg text-sm font-medium transition-colors <%= activePage === 'home' ? 'text-brand-red bg-red-50' : 'text-slate-600 hover:text-brand-red hover:bg-red-50' %>">Home</a>
            </li>
            <li>
              <a href="/trading-cards" class="px-3 py-2 rounded-lg text-sm font-medium transition-colors <%= activePage === 'trading-cards' ? 'text-brand-blue bg-blue-50' : 'text-slate-600 hover:text-brand-blue hover:bg-blue-50' %>">Trading Cards</a>
            </li>
            <li>
              <a href="/greeting-cards" class="px-3 py-2 rounded-lg text-sm font-medium transition-colors <%= activePage === 'greeting-cards' ? 'text-brand-red bg-red-50' : 'text-slate-600 hover:text-brand-red hover:bg-red-50' %>">Greeting Cards</a>
            </li>
            <li>
              <a href="/greeting-cards#seasonal-holiday" class="px-3 py-2 rounded-lg text-sm font-medium transition-colors <%= activePage === 'holiday-cards' ? 'text-brand-orange bg-orange-50' : 'text-slate-600 hover:text-brand-orange hover:bg-orange-50' %>">Holiday Cards</a>
            </li>
            <li>
              <a href="/gifts-balloons" class="px-3 py-2 rounded-lg text-sm font-medium transition-colors <%= activePage === 'gifts-balloons' ? 'text-brand-blue bg-blue-50' : 'text-slate-600 hover:text-brand-blue hover:bg-blue-50' %>">Gifts & Balloons</a>
            </li>
            <li>
              <a href="/cigars" class="px-3 py-2 rounded-lg text-sm font-medium transition-colors <%= activePage === 'cigars' ? 'text-amber-600 bg-amber-50' : 'text-slate-600 hover:text-amber-600 hover:bg-amber-50' %>">Cigars</a>
            </li>
            <li>
              <a href="/contact" class="ml-2 px-4 py-2 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-red-500 to-orange-500 hover:from-red-600 hover:to-orange-600 shadow-md hover:shadow-lg transition-all <%= activePage === 'contact' ? 'ring-2 ring-offset-2 ring-orange-400' : '' %>">Contact</a>
            </li>
          </ul>
          <button id="mobile-menu-btn" type="button" class="lg:hidden p-2 rounded-lg text-slate-700 hover:bg-slate-100" aria-expanded="false" aria-label="Open menu">
            <svg id="icon-menu" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
            <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <div id="mobile-menu" class="hidden lg:hidden mb-3 rounded-2xl bg-white shadow-xl border border-slate-100 overflow-hidden">
          <ul class="py-2">
            <li><a href="/" class="mobile-nav-link block px-5 py-3 <%= activePage === 'home' ? 'text-brand-red font-medium bg-red-50' : 'text-slate-700 hover:bg-slate-50' %>">Home</a></li>
            <li><a href="/trading-cards" class="mobile-nav-link block px-5 py-3 <%= activePage === 'trading-cards' ? 'text-brand-blue font-medium bg-blue-50' : 'text-slate-700 hover:bg-slate-50' %>">Trading Cards</a></li>
            <li><a href="/greeting-cards" class="mobile-nav-link block px-5 py-3 <%= activePage === 'greeting-cards' ? 'text-brand-red font-medium bg-red-50' : 'text-slate-700 hover:bg-slate-50' %>">Greeting Cards</a></li>
            <li><a href="/greeting-cards#seasonal-holiday" class="mobile-nav-link block px-5 py-3 <%= activePage === 'holiday-cards' ? 'text-brand-orange font-medium bg-orange-50' : 'text-slate-700 hover:bg-slate-50' %>">Holiday Cards</a></li>
            <li><a href="/gifts-balloons" class="mobile-nav-link block px-5 py-3 <%= activePage === 'gifts-balloons' ? 'text-brand-blue font-medium bg-blue-50' : 'text-slate-700 hover:bg-slate-50' %>">Gifts & Balloons</a></li>
            <li><a href="/cigars" class="mobile-nav-link block px-5 py-3 <%= activePage === 'cigars' ? 'text-amber-600 font-medium bg-amber-50' : 'text-slate-700 hover:bg-slate-50' %>">Cigars</a></li>
            <li><a href="/contact" class="mobile-nav-link block px-5 py-3 text-brand-red font-semibold">Contact</a></li>
          </ul>
        </div>
      </nav>
    </header>
