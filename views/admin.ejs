<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard | Prabhu Cards & Gifts</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="font-sans bg-slate-50 text-slate-800 antialiased">
    <div class="min-h-screen">
      <header class="bg-white border-b border-slate-200 sticky top-0 z-40">
        <div class="container mx-auto px-4 py-4 max-w-7xl flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div class="flex items-center gap-3">
            <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-red-500 via-blue-500 to-orange-500 text-white font-display font-bold text-lg">P</span>
            <div>
              <h1 class="font-display text-xl font-bold text-slate-900">Admin Dashboard</h1>
              <p class="text-sm text-slate-500">Signed in as <%= adminEmail %></p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <a href="/" class="px-4 py-2 rounded-xl bg-slate-100 text-sm font-semibold hover:bg-slate-200 transition-colors">View Store</a>
            <form method="POST" action="/admin/logout">
              <button type="submit" class="px-4 py-2 rounded-xl border border-slate-200 text-sm font-semibold hover:bg-slate-100 transition-colors">
                Sign Out
              </button>
            </form>
          </div>
        </div>
      </header>

      <main class="container mx-auto px-4 py-8 max-w-7xl">
        <% if (flash) { %>
          <div class="mb-6 rounded-xl px-4 py-3 text-sm border <%= flash.type === 'error' ? 'bg-red-50 text-red-700 border-red-200' : 'bg-green-50 text-green-700 border-green-200' %>" role="status">
            <%= flash.message %>
          </div>
        <% } %>

        <div class="flex flex-wrap gap-2 mb-8 border-b border-slate-200 pb-4">
          <a href="/admin?tab=credentials" class="px-4 py-2 rounded-xl text-sm font-semibold transition-colors <%= activeTab === 'credentials' ? 'bg-brand-blue text-white' : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-100' %>">
            Credentials
          </a>
          <a href="/admin?tab=inventory" class="px-4 py-2 rounded-xl text-sm font-semibold transition-colors <%= activeTab === 'inventory' ? 'bg-brand-blue text-white' : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-100' %>">
            Product Management
          </a>
          <a href="/admin?tab=inquiries" class="px-4 py-2 rounded-xl text-sm font-semibold transition-colors <%= activeTab === 'inquiries' ? 'bg-brand-blue text-white' : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-100' %>">
            Inquiry Logger
          </a>
          <a href="/admin?tab=photos" class="px-4 py-2 rounded-xl text-sm font-semibold transition-colors <%= activeTab === 'photos' ? 'bg-brand-blue text-white' : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-100' %>">
            Site Photos
          </a>
          <a href="/admin?tab=branding" class="px-4 py-2 rounded-xl text-sm font-semibold transition-colors <%= activeTab === 'branding' ? 'bg-brand-blue text-white' : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-100' %>">
            Website Branding
          </a>
          <a href="/admin?tab=lottery" class="px-4 py-2 rounded-xl text-sm font-semibold transition-colors <%= activeTab === 'lottery' ? 'bg-brand-blue text-white' : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-100' %>">
            Lottery
          </a>
        </div>

        <% if (activeTab === 'credentials') { %>
          <div class="mb-6 rounded-xl bg-slate-100 border border-slate-200 px-4 py-3 text-sm text-slate-700">
            Current login email: <strong class="text-slate-900"><%= adminEmail %></strong>
            <span class="block mt-1 text-slate-500">To save changes, enter your <em>current</em> password in the form below. After saving, use the new email/password on your next sign-in.</span>
          </div>
          <div class="grid lg:grid-cols-2 gap-6">
            <section class="bg-white rounded-2xl shadow-md border border-slate-100 p-6">
              <h2 class="font-display text-xl font-bold text-slate-900 mb-1">Update Email</h2>
              <p class="text-sm text-slate-500 mb-6">Change the administrator login email address.</p>
              <form method="POST" action="/admin/settings/email" class="space-y-4" autocomplete="off">
                <div>
                  <label for="email" class="block text-sm font-medium text-slate-700 mb-1">New Email</label>
                  <input type="email" id="email" name="email" required value="<%= adminEmail %>" autocomplete="off" class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none" />
                </div>
                <div>
                  <label for="email-current-password" class="block text-sm font-medium text-slate-700 mb-1">Current Password (required to save)</label>
                  <input type="password" id="email-current-password" name="current_password" required autocomplete="current-password" class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none" placeholder="Enter current password" />
                </div>
                <button type="submit" class="px-5 py-2.5 rounded-xl bg-brand-blue text-white text-sm font-semibold hover:bg-blue-700 transition-colors">
                  Save Email
                </button>
              </form>
            </section>

            <section class="bg-white rounded-2xl shadow-md border border-slate-100 p-6">
              <h2 class="font-display text-xl font-bold text-slate-900 mb-1">Change Password</h2>
              <p class="text-sm text-slate-500 mb-6">Use a strong password with at least 8 characters.</p>
              <form method="POST" action="/admin/settings/password" class="space-y-4" autocomplete="off">
                <div>
                  <label for="current-password" class="block text-sm font-medium text-slate-700 mb-1">Current Password (required to save)</label>
                  <input type="password" id="current-password" name="current_password" required autocomplete="current-password" class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none" placeholder="Enter current password" />
                </div>
                <div>
                  <label for="new-password" class="block text-sm font-medium text-slate-700 mb-1">New Password</label>
                  <input type="password" id="new-password" name="new_password" required minlength="8" autocomplete="new-password" class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none" />
                </div>
                <div>
                  <label for="confirm-password" class="block text-sm font-medium text-slate-700 mb-1">Confirm New Password</label>
                  <input type="password" id="confirm-password" name="confirm_password" required minlength="8" autocomplete="new-password" class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none" />
                </div>
                <button type="submit" class="px-5 py-2.5 rounded-xl bg-brand-red text-white text-sm font-semibold hover:bg-red-700 transition-colors">
                  Update Password
                </button>
              </form>
            </section>
          </div>

          <section class="mt-6 bg-white rounded-2xl shadow-md border border-slate-100 p-6">
            <h2 class="font-display text-xl font-bold text-slate-900 mb-1">Store Hours</h2>
            <p class="text-sm text-slate-500 mb-6">Displayed on the Contact page. Changes are saved to PostgreSQL and persist across restarts.</p>
            <form method="POST" action="/admin/settings/hours" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
              <div>
                <label for="weekday-days" class="block text-sm font-medium text-slate-700 mb-1">Weekday label</label>
                <input type="text" id="weekday-days" name="weekday_days" value="<%= storeHours.weekday_days %>" class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none" />
              </div>
              <div>
                <label for="weekday-open" class="block text-sm font-medium text-slate-700 mb-1">Weekday open</label>
                <input type="text" id="weekday-open" name="weekday_open" value="<%= storeHours.weekday_open %>" class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none" />
              </div>
              <div>
                <label for="weekday-close" class="block text-sm font-medium text-slate-700 mb-1">Weekday close</label>
                <input type="text" id="weekday-close" name="weekday_close" value="<%= storeHours.weekday_close %>" class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none" />
              </div>
              <div>
                <label for="sunday-days" class="block text-sm font-medium text-slate-700 mb-1">Sunday label</label>
                <input type="text" id="sunday-days" name="sunday_days" value="<%= storeHours.sunday_days %>" class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none" />
              </div>
              <div>
                <label for="sunday-open" class="block text-sm font-medium text-slate-700 mb-1">Sunday open</label>
                <input type="text" id="sunday-open" name="sunday_open" value="<%= storeHours.sunday_open %>" class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none" />
              </div>
              <div>
                <label for="sunday-close" class="block text-sm font-medium text-slate-700 mb-1">Sunday close</label>
                <input type="text" id="sunday-close" name="sunday_close" value="<%= storeHours.sunday_close %>" class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none" />
              </div>
              <div class="sm:col-span-2 lg:col-span-3">
                <button type="submit" class="px-5 py-2.5 rounded-xl bg-brand-blue text-white text-sm font-semibold hover:bg-blue-700 transition-colors">
                  Save Store Hours
                </button>
              </div>
            </form>
          </section>
        <% } %>

        <% if (activeTab === 'inventory') { %>
          <div class="grid xl:grid-cols-3 gap-6">
            <section class="xl:col-span-1 bg-white rounded-2xl shadow-md border border-slate-100 p-6 h-fit">
              <h2 class="font-display text-xl font-bold text-slate-900 mb-1">Add Product</h2>
              <p class="text-sm text-slate-500 mb-6">New items appear on the storefront immediately.</p>
              <form method="POST" action="/admin/inventory/add" class="space-y-4" data-photo-form data-photo-optional="true">
                <div>
                  <label for="product-name" class="block text-sm font-medium text-slate-700 mb-1">Product Name</label>
                  <input type="text" id="product-name" name="name" required class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none" placeholder="e.g. Rookie Football Box" />
                </div>
                <div>
                  <label for="department" class="block text-sm font-medium text-slate-700 mb-1">Department</label>
                  <select id="department" name="department" required class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none bg-white">
                    <option value="">Select department...</option>
                    <% departments.forEach(function(dept) { %>
                      <option value="<%= dept.value %>"><%= dept.label %></option>
                    <% }); %>
                  </select>
                  <p class="mt-1 text-xs text-slate-500">Trading cards are saved under the sport/department you select.</p>
                </div>
                <div>
                  <label for="price" class="block text-sm font-medium text-slate-700 mb-1">Price (USD)</label>
                  <input type="number" id="price" name="price" min="0" step="0.01" inputmode="decimal" class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none" placeholder="e.g. 12.99" />
                  <p class="mt-1 text-xs text-slate-500">Optional. Leave blank if price varies or is in-store only.</p>
                </div>
                <div>
                  <label for="description" class="block text-sm font-medium text-slate-700 mb-1">Description</label>
                  <textarea id="description" name="description" rows="3" class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none resize-none" placeholder="Short product description"></textarea>
                </div>
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">Product Photo</label>
                  <div data-photo-widget class="space-y-3">
                    <div data-photo-preview class="w-full aspect-[4/3] rounded-xl border-2 border-dashed border-slate-200 bg-slate-50 flex items-center justify-center overflow-hidden text-slate-400">
                      <span class="text-sm">No photo yet</span>
                    </div>
                    <input type="hidden" name="image_url" data-photo-url />
                    <div class="flex flex-wrap gap-2">
                      <button type="button" data-photo-take class="flex-1 min-w-[140px] px-4 py-2.5 rounded-xl bg-brand-blue text-white text-sm font-semibold hover:bg-blue-700 transition-colors inline-flex items-center justify-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        Take Photo
                      </button>
                      <button type="button" data-photo-clear class="px-4 py-2.5 rounded-xl border border-slate-200 text-sm font-semibold text-slate-600 hover:bg-slate-50 transition-colors">
                        Clear
                      </button>
                    </div>
                    <p class="text-xs text-slate-500">Use your device camera or upload an image. Photos appear on the storefront right away.</p>
                  </div>
                </div>
                <button type="submit" class="w-full py-3 rounded-xl bg-gradient-to-r from-red-500 to-orange-500 text-white font-semibold shadow-md hover:shadow-lg transition-all">
                  Add to Inventory
                </button>
              </form>
            </section>

            <section class="xl:col-span-2 bg-white rounded-2xl shadow-md border border-slate-100 overflow-hidden">
              <div class="px-6 py-4 border-b border-slate-100">
                <h2 class="font-display text-xl font-bold text-slate-900">Current Inventory</h2>
                <p class="text-sm text-slate-500"><%= inventory.length %> product<%= inventory.length === 1 ? '' : 's' %> (including hidden). Edit, hide/show, reorder, and delete — all saved to PostgreSQL.</p>
              </div>
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead class="bg-slate-100 text-slate-700">
                    <tr>
                      <th class="text-left px-4 py-3 font-semibold">Photo</th>
                      <th class="text-left px-4 py-3 font-semibold">Name</th>
                      <th class="text-left px-4 py-3 font-semibold">Department</th>
                      <th class="text-left px-4 py-3 font-semibold">Price</th>
                      <th class="text-left px-4 py-3 font-semibold">Status</th>
                      <th class="text-right px-4 py-3 font-semibold">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (!inventory.length) { %>
                      <tr>
                        <td colspan="6" class="px-4 py-10 text-center text-slate-500">No inventory items yet. Add your first product using the form.</td>
                      </tr>
                    <% } %>
                    <% inventory.forEach(function(item) {
                      var deptValue = item.subcategory === 'trading-cards' && item.sport_type
                        ? 'trading-cards:' + item.sport_type
                        : item.subcategory;
                      var isEditing = editItemId === item.id;
                    %>
                      <tr class="border-t border-slate-100 hover:bg-slate-50 <%= item.in_stock ? '' : 'opacity-70 bg-slate-50' %>">
                        <td class="px-4 py-3" colspan="<%= isEditing ? 6 : 1 %>">
                          <% if (isEditing) { %>
                            <form method="POST" action="/admin/inventory/edit/<%= item.id %>" class="space-y-3" data-photo-form data-photo-optional="true">
                              <div class="grid sm:grid-cols-2 gap-3">
                                <div>
                                  <label class="block text-xs font-medium text-slate-600 mb-1">Name</label>
                                  <input type="text" name="name" required value="<%= item.name %>" class="form-input w-full px-3 py-2 rounded-lg border border-slate-200 focus:outline-none" />
                                </div>
                                <div>
                                  <label class="block text-xs font-medium text-slate-600 mb-1">Department</label>
                                  <select name="department" required class="form-input w-full px-3 py-2 rounded-lg border border-slate-200 focus:outline-none bg-white">
                                    <% departments.forEach(function(dept) { %>
                                      <option value="<%= dept.value %>" <%= dept.value === deptValue ? 'selected' : '' %>><%= dept.label %></option>
                                    <% }); %>
                                  </select>
                                </div>
                                <div>
                                  <label class="block text-xs font-medium text-slate-600 mb-1">Price</label>
                                  <input type="number" name="price" min="0" step="0.01" value="<%= item.price != null ? item.price : '' %>" class="form-input w-full px-3 py-2 rounded-lg border border-slate-200 focus:outline-none" />
                                </div>
                                <div>
                                  <label class="block text-xs font-medium text-slate-600 mb-1">Photo</label>
                                  <div data-photo-widget class="space-y-2">
                                    <div data-photo-preview class="w-20 h-20 rounded-lg border border-slate-200 bg-slate-50 overflow-hidden flex items-center justify-center text-slate-400 text-xs">
                                      <% if (item.image_url) { %>
                                        <img src="<%= item.image_url %>" alt="" class="w-full h-full object-cover" />
                                      <% } else { %>
                                        <span>No photo</span>
                                      <% } %>
                                    </div>
                                    <input type="hidden" name="image_url" data-photo-url value="<%= item.image_url || '' %>" />
                                    <button type="button" data-photo-take class="px-3 py-2 rounded-lg text-xs font-semibold text-brand-blue bg-blue-50 hover:bg-blue-100">Take/Upload Photo</button>
                                  </div>
                                </div>
                                <div class="sm:col-span-2">
                                  <label class="block text-xs font-medium text-slate-600 mb-1">Description</label>
                                  <textarea name="description" rows="2" class="form-input w-full px-3 py-2 rounded-lg border border-slate-200 focus:outline-none resize-none"><%= item.description || '' %></textarea>
                                </div>
                              </div>
                              <div class="flex flex-wrap gap-2">
                                <button type="submit" class="px-4 py-2 rounded-lg text-xs font-semibold text-white bg-brand-blue hover:bg-blue-700">Save Changes</button>
                                <a href="/admin?tab=inventory" class="px-4 py-2 rounded-lg text-xs font-semibold text-slate-600 bg-slate-100 hover:bg-slate-200">Cancel</a>
                              </div>
                            </form>
                          <% } else { %>
                          <div class="flex items-center gap-2">
                            <div class="w-14 h-14 rounded-lg overflow-hidden bg-slate-100 border border-slate-200 shrink-0">
                              <% if (item.image_url) { %>
                                <img src="<%= item.image_url %>" alt="<%= item.name %>" class="w-full h-full object-cover" />
                              <% } else { %>
                                <div class="w-full h-full flex items-center justify-center text-slate-400 text-xs">No photo</div>
                              <% } %>
                            </div>
                            <form id="photo-form-<%= item.id %>" method="POST" action="/admin/inventory/image/<%= item.id %>" class="inline">
                              <input type="hidden" name="image_url" data-photo-url value="<%= item.image_url || '' %>" />
                              <button type="button" data-photo-trigger data-photo-form="photo-form-<%= item.id %>" class="px-2 py-1 rounded-lg text-xs font-semibold text-brand-blue bg-blue-50 hover:bg-blue-100 transition-colors whitespace-nowrap">
                                Change
                              </button>
                            </form>
                          </div>
                          <% } %>
                        </td>
                        <% if (!isEditing) { %>
                        <td class="px-4 py-3 font-medium text-slate-900">
                          <% if (item.subcategory === 'trading-cards' && item.in_stock) { %>
                            <a href="/trading-cards/<%= item.id %>" class="hover:text-brand-blue hover:underline"><%= item.name %></a>
                          <% } else { %>
                            <%= item.name %>
                          <% } %>
                        </td>
                        <td class="px-4 py-3 text-slate-600 whitespace-nowrap">
                          <% if (item.subcategory === 'trading-cards' && item.sport_type) { %>
                            Trading Cards — <%= sportLabels[item.sport_type] || item.sport_type %>
                          <% } else if (item.subcategory === 'willow-tree') { %>
                            Willow Tree Figurines
                          <% } else if (item.subcategory === 'gifts') { %>
                            Gifts
                          <% } else if (item.subcategory === 'balloons') { %>
                            Balloons
                          <% } else { %>
                            <%= item.subcategory %>
                          <% } %>
                        </td>
                        <td class="px-4 py-3 text-slate-700 whitespace-nowrap font-medium">
                          <%= formatPrice(item.price) || '—' %>
                        </td>
                        <td class="px-4 py-3 whitespace-nowrap">
                          <span class="inline-flex px-2 py-1 rounded-full text-xs font-semibold <%= item.in_stock ? 'bg-green-50 text-green-700' : 'bg-slate-200 text-slate-600' %>">
                            <%= item.in_stock ? 'Visible' : 'Hidden' %>
                          </span>
                        </td>
                        <td class="px-4 py-3 text-right">
                          <div class="inline-flex flex-wrap justify-end gap-1">
                            <a href="/admin?tab=inventory&edit=<%= item.id %>" class="px-2 py-1.5 rounded-lg text-xs font-semibold text-brand-blue bg-blue-50 hover:bg-blue-100">Edit</a>
                            <form method="POST" action="/admin/inventory/toggle/<%= item.id %>" class="inline">
                              <button type="submit" class="px-2 py-1.5 rounded-lg text-xs font-semibold text-slate-700 bg-slate-100 hover:bg-slate-200">
                                <%= item.in_stock ? 'Hide' : 'Show' %>
                              </button>
                            </form>
                            <form method="POST" action="/admin/inventory/reorder/<%= item.id %>" class="inline">
                              <input type="hidden" name="direction" value="up" />
                              <button type="submit" class="px-2 py-1.5 rounded-lg text-xs font-semibold text-slate-700 bg-slate-100 hover:bg-slate-200" title="Move up">↑</button>
                            </form>
                            <form method="POST" action="/admin/inventory/reorder/<%= item.id %>" class="inline">
                              <input type="hidden" name="direction" value="down" />
                              <button type="submit" class="px-2 py-1.5 rounded-lg text-xs font-semibold text-slate-700 bg-slate-100 hover:bg-slate-200" title="Move down">↓</button>
                            </form>
                            <form method="POST" action="/admin/inventory/delete/<%= item.id %>" class="inline" onsubmit="return confirm('Delete this product from inventory?');">
                              <button type="submit" class="px-2 py-1.5 rounded-lg text-xs font-semibold text-red-600 bg-red-50 hover:bg-red-100">
                                Delete
                              </button>
                            </form>
                          </div>
                        </td>
                        <% } %>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            </section>
          </div>
        <% } %>

        <% if (activeTab === 'lottery') { %>
          <div class="grid xl:grid-cols-3 gap-6">
            <section class="xl:col-span-1 bg-white rounded-2xl shadow-md border border-slate-100 p-6 h-fit">
              <h2 class="font-display text-xl font-bold text-slate-900 mb-1">Lottery Page</h2>
              <p class="text-sm text-slate-500 mb-6">Edit title, visibility, hero image, and copy. Saved to PostgreSQL.</p>
              <form method="POST" action="/admin/lottery/page" class="space-y-4" data-photo-form data-photo-optional="true">
                <label class="flex items-center gap-2 text-sm font-medium text-slate-700">
                  <input type="checkbox" name="visible" value="on" <%= lotteryPage && lotteryPage.visible ? 'checked' : '' %> class="rounded border-slate-300" />
                  Show Lottery in navigation and on the public site
                </label>
                <div>
                  <label for="lottery-title" class="block text-sm font-medium text-slate-700 mb-1">Title</label>
                  <input type="text" id="lottery-title" name="title" value="<%= lotteryPage ? lotteryPage.title : 'Lottery' %>" required class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none" />
                </div>
                <div>
                  <label for="lottery-subtitle" class="block text-sm font-medium text-slate-700 mb-1">Subtitle</label>
                  <input type="text" id="lottery-subtitle" name="subtitle" value="<%= lotteryPage ? (lotteryPage.subtitle || '') : '' %>" class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none" />
                </div>
                <div>
                  <label for="lottery-description" class="block text-sm font-medium text-slate-700 mb-1">Description</label>
                  <textarea id="lottery-description" name="description" rows="4" class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none resize-none"><%= lotteryPage ? (lotteryPage.description || '') : '' %></textarea>
                </div>
                <div>
                  <label for="lottery-disclaimer" class="block text-sm font-medium text-slate-700 mb-1">Disclaimer</label>
                  <textarea id="lottery-disclaimer" name="disclaimer" rows="2" class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none resize-none"><%= lotteryPage ? (lotteryPage.disclaimer || '') : '' %></textarea>
                </div>
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">Hero Photo</label>
                  <div data-photo-widget class="space-y-3">
                    <div data-photo-preview class="w-full aspect-[16/10] rounded-xl border-2 border-dashed border-slate-200 bg-slate-50 flex items-center justify-center overflow-hidden text-slate-400">
                      <% if (lotteryPage && lotteryPage.hero_image_url) { %>
                        <img src="<%= lotteryPage.hero_image_url %>" alt="Lottery hero" class="w-full h-full object-cover" />
                      <% } else { %>
                        <span class="text-sm">No photo yet</span>
                      <% } %>
                    </div>
                    <input type="hidden" name="hero_image_url" data-photo-url value="<%= lotteryPage && lotteryPage.hero_image_url ? lotteryPage.hero_image_url : '' %>" />
                    <button type="button" data-photo-take class="w-full px-4 py-2.5 rounded-xl bg-brand-blue text-white text-sm font-semibold hover:bg-blue-700">Take / Upload Hero Photo</button>
                  </div>
                </div>
                <button type="submit" class="w-full py-3 rounded-xl bg-gradient-to-r from-red-500 to-orange-500 text-white font-semibold shadow-md hover:shadow-lg transition-all">
                  Save Lottery Page
                </button>
              </form>
            </section>

            <section class="xl:col-span-2 space-y-6">
              <div class="bg-white rounded-2xl shadow-md border border-slate-100 p-6">
                <h2 class="font-display text-xl font-bold text-slate-900 mb-1">Add Lottery Section</h2>
                <p class="text-sm text-slate-500 mb-6">Sections appear as content cards on the public Lottery page.</p>
                <form method="POST" action="/admin/lottery/sections/add" class="space-y-4" data-photo-form data-photo-optional="true">
                  <div>
                    <label for="section-title" class="block text-sm font-medium text-slate-700 mb-1">Title</label>
                    <input type="text" id="section-title" name="title" required class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none" />
                  </div>
                  <div>
                    <label for="section-description" class="block text-sm font-medium text-slate-700 mb-1">Description</label>
                    <textarea id="section-description" name="description" rows="3" class="form-input w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none resize-none"></textarea>
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Section Photo</label>
                    <div data-photo-widget class="space-y-3">
                      <div data-photo-preview class="w-full aspect-[16/10] rounded-xl border-2 border-dashed border-slate-200 bg-slate-50 flex items-center justify-center overflow-hidden text-slate-400">
                        <span class="text-sm">No photo yet</span>
                      </div>
                      <input type="hidden" name="image_url" data-photo-url />
                      <button type="button" data-photo-take class="px-4 py-2.5 rounded-xl bg-brand-blue text-white text-sm font-semibold hover:bg-blue-700">Take / Upload Photo</button>
                    </div>
                  </div>
                  <button type="submit" class="px-5 py-2.5 rounded-xl bg-brand-blue text-white text-sm font-semibold hover:bg-blue-700">Add Section</button>
                </form>
              </div>

              <div class="bg-white rounded-2xl shadow-md border border-slate-100 overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100">
                  <h2 class="font-display text-xl font-bold text-slate-900">Lottery Sections</h2>
                  <p class="text-sm text-slate-500"><%= lotterySections.length %> section<%= lotterySections.length === 1 ? '' : 's' %></p>
                </div>
                <div class="divide-y divide-slate-100">
                  <% if (!lotterySections.length) { %>
                    <p class="px-6 py-10 text-center text-slate-500">No sections yet.</p>
                  <% } %>
                  <% lotterySections.forEach(function(section) { %>
                    <div class="p-6 <%= section.visible ? '' : 'bg-slate-50 opacity-80' %>">
                      <form method="POST" action="/admin/lottery/sections/edit/<%= section.id %>" class="space-y-3" data-photo-form data-photo-optional="true">
                        <div class="flex flex-wrap items-start gap-4" data-photo-widget>
                          <div data-photo-preview class="w-28 h-20 rounded-lg overflow-hidden bg-slate-100 border shrink-0 flex items-center justify-center text-xs text-slate-400">
                            <% if (section.image_url) { %>
                              <img src="<%= section.image_url %>" alt="<%= section.title %>" class="w-full h-full object-cover" />
                            <% } else { %>
                              <span>No photo</span>
                            <% } %>
                          </div>
                          <div class="flex-1 min-w-[200px] space-y-2">
                            <input type="text" name="title" required value="<%= section.title %>" class="form-input w-full px-3 py-2 rounded-lg border border-slate-200 focus:outline-none font-semibold" />
                            <textarea name="description" rows="2" class="form-input w-full px-3 py-2 rounded-lg border border-slate-200 focus:outline-none resize-none text-sm"><%= section.description || '' %></textarea>
                            <input type="hidden" name="image_url" data-photo-url value="<%= section.image_url || '' %>" />
                            <div class="flex flex-wrap gap-2">
                              <button type="button" data-photo-take class="px-3 py-1.5 rounded-lg text-xs font-semibold text-brand-blue bg-blue-50 hover:bg-blue-100">Change Photo</button>
                              <button type="submit" class="px-3 py-1.5 rounded-lg text-xs font-semibold text-white bg-brand-blue hover:bg-blue-700">Save</button>
                              <button formaction="/admin/lottery/sections/toggle/<%= section.id %>" formmethod="POST" type="submit" formnovalidate class="px-3 py-1.5 rounded-lg text-xs font-semibold text-slate-700 bg-slate-100 hover:bg-slate-200">
                                <%= section.visible ? 'Hide' : 'Show' %>
                              </button>
                              <button formaction="/admin/lottery/sections/reorder/<%= section.id %>" formmethod="POST" type="submit" formnovalidate name="direction" value="up" class="px-3 py-1.5 rounded-lg text-xs font-semibold text-slate-700 bg-slate-100 hover:bg-slate-200">↑</button>
                              <button formaction="/admin/lottery/sections/reorder/<%= section.id %>" formmethod="POST" type="submit" formnovalidate name="direction" value="down" class="px-3 py-1.5 rounded-lg text-xs font-semibold text-slate-700 bg-slate-100 hover:bg-slate-200">↓</button>
                              <button formaction="/admin/lottery/sections/delete/<%= section.id %>" formmethod="POST" type="submit" formnovalidate class="px-3 py-1.5 rounded-lg text-xs font-semibold text-red-600 bg-red-50 hover:bg-red-100" onclick="return confirm('Delete this Lottery section?');">Delete</button>
                            </div>
                          </div>
                        </div>
                      </form>
                    </div>
                  <% }); %>
                </div>
              </div>
            </section>
          </div>
        <% } %>

        <% if (activeTab === 'branding') { %>
          <section class="bg-white rounded-2xl shadow-md border border-slate-100 p-6 max-w-xl">
            <h2 class="font-display text-xl font-bold text-slate-900 mb-1">Website Branding</h2>
            <p class="text-sm text-slate-500 mb-8">Upload a logo for the site header. Stored in Supabase Storage; the URL is saved in PostgreSQL. If no logo is set, the default P placeholder is shown.</p>
            <form method="POST" action="/admin/settings/logo" class="space-y-6" data-photo-form data-photo-optional="true">
              <div data-photo-widget class="space-y-4">
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">Logo preview</label>
                  <div data-photo-preview data-photo-fit="contain" data-photo-empty-label="Default P placeholder" class="h-[90px] w-[90px] rounded-xl border border-slate-200 bg-slate-50 flex items-center justify-center overflow-hidden <%= logoUrl ? '' : 'border-dashed text-slate-400' %>">
                    <% if (logoUrl) { %>
                      <img src="<%= logoUrl %>" alt="Current website logo" class="w-full h-full object-contain" />
                    <% } else { %>
                      <span class="flex h-[45px] w-[45px] items-center justify-center rounded-xl bg-gradient-to-br from-red-500 via-blue-500 to-orange-500 text-white font-display font-bold text-lg shadow-md">P</span>
                    <% } %>
                  </div>
                  <p class="mt-2 text-xs text-slate-500">Displayed at about 45×45px with rounded corners on the live site.</p>
                </div>
                <input type="hidden" name="logo_url" data-photo-url value="<%= logoUrl || '' %>" />
                <div class="flex flex-wrap gap-2">
                  <button type="button" data-photo-take class="px-4 py-2.5 rounded-xl bg-brand-blue text-white text-sm font-semibold hover:bg-blue-700 transition-colors inline-flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <%= logoUrl ? 'Replace Logo' : 'Upload Logo' %>
                  </button>
                  <button type="button" data-photo-clear class="px-4 py-2.5 rounded-xl border border-slate-200 text-sm font-semibold text-slate-600 hover:bg-slate-50 transition-colors">
                    Remove Logo
                  </button>
                </div>
              </div>
              <button type="submit" class="px-5 py-2.5 rounded-xl bg-gradient-to-r from-red-500 to-orange-500 text-white text-sm font-semibold shadow-md hover:shadow-lg transition-all">
                Save Changes
              </button>
            </form>
          </section>
        <% } %>

        <% if (activeTab === 'photos') { %>
          <section class="bg-white rounded-2xl shadow-md border border-slate-100 p-6">
            <h2 class="font-display text-xl font-bold text-slate-900 mb-1">Site Photos</h2>
            <p class="text-sm text-slate-500 mb-8">Take or upload photos for the homepage, category cards, and page banners. Changes appear on the live site immediately.</p>
            <div class="grid sm:grid-cols-2 xl:grid-cols-3 gap-6">
              <% siteImages.forEach(function(slot) { %>
                <div class="rounded-2xl border border-slate-100 overflow-hidden bg-slate-50">
                  <div class="aspect-[16/10] bg-slate-200">
                    <img src="<%= slot.imageUrl %>" alt="<%= slot.label %>" class="w-full h-full object-cover" />
                  </div>
                  <div class="p-4 space-y-3">
                    <h3 class="font-semibold text-slate-900 text-sm"><%= slot.label %></h3>
                    <form id="site-photo-<%= slot.key %>" method="POST" action="/admin/site-images/<%= slot.key %>">
                      <input type="hidden" name="image_url" data-photo-url value="<%= slot.imageUrl %>" />
                      <button type="button" data-photo-trigger data-photo-form="site-photo-<%= slot.key %>" class="w-full px-4 py-2.5 rounded-xl bg-brand-blue text-white text-sm font-semibold hover:bg-blue-700 transition-colors inline-flex items-center justify-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        Take New Photo
                      </button>
                    </form>
                  </div>
                </div>
              <% }); %>
            </div>
          </section>
        <% } %>

        <% if (activeTab === 'inquiries') { %>
          <section class="bg-white rounded-2xl shadow-md border border-slate-100 overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100">
              <h2 class="font-display text-xl font-bold text-slate-900">Customer Inquiries</h2>
              <p class="text-sm text-slate-500">Messages submitted through the contact form.</p>
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead class="bg-slate-100 text-slate-700">
                  <tr>
                    <th class="text-left px-4 py-3 font-semibold">Date</th>
                    <th class="text-left px-4 py-3 font-semibold">Name</th>
                    <th class="text-left px-4 py-3 font-semibold">Email</th>
                    <th class="text-left px-4 py-3 font-semibold hidden sm:table-cell">Phone</th>
                    <th class="text-left px-4 py-3 font-semibold">Message</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!contacts.length) { %>
                    <tr>
                      <td colspan="5" class="px-4 py-10 text-center text-slate-500">No customer messages yet.</td>
                    </tr>
                  <% } %>
                  <% contacts.forEach(function(contact) { %>
                    <tr class="border-t border-slate-100 hover:bg-slate-50 align-top">
                      <td class="px-4 py-3 whitespace-nowrap text-slate-500"><%= new Date(contact.created_at).toLocaleString() %></td>
                      <td class="px-4 py-3 font-medium"><%= contact.name %></td>
                      <td class="px-4 py-3"><a href="mailto:<%= contact.email %>" class="text-brand-blue hover:underline"><%= contact.email %></a></td>
                      <td class="px-4 py-3 hidden sm:table-cell"><%= contact.phone || '—' %></td>
                      <td class="px-4 py-3 max-w-md text-slate-600"><%= contact.message %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </section>
        <% } %>
      </main>
    </div>
    <script src="/js/admin-camera.js"></script>
  </body>
</html>
