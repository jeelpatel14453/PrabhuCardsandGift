  <!-- CTA -->
  <section class="py-16 bg-gradient-to-r from-red-500 to-orange-500 text-white text-center">
    <div class="container mx-auto px-4 fade-in">
      <h2 class="font-display text-2xl sm:text-3xl font-bold mb-4">Need Help Finding the Right Card?</h2>
      <p class="mb-6 text-white/90 max-w-xl mx-auto">Our friendly team is happy to help you pick the perfect greeting or holiday card for any occasion.</p>
      <a href="/contact" class="inline-block px-6 py-3 bg-white text-brand-red font-semibold rounded-xl shadow-lg hover:scale-105 transition-transform">
        Visit Us or Call 631-399-2808
      </a>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
