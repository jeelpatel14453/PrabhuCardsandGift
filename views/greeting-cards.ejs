<%- include('partials/header', {
  title: 'Greeting Cards | Prabhu Cards & Gifts',
  description: 'Shop birthday, wedding, sympathy, graduation, and seasonal holiday greeting cards at Prabhu Cards & Gifts in Manorville, NY.',
  activePage: 'greeting-cards'
}) %>

<main id="main-content" class="pt-24">
  <!-- PAGE HERO -->
  <section class="relative py-20 text-white">
    <div class="absolute inset-0">
      <img
        src="<%= siteImage('greeting-cards.hero') %>"
        alt="Greeting cards display at Prabhu Cards & Gifts"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 page-hero-gradient"></div>
    </div>
    <div class="relative container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-display text-4xl sm:text-5xl font-extrabold mb-4 fade-in">Greeting Cards</h1>
      <p class="max-w-2xl mx-auto text-lg text-white/90 fade-in">
        Find the perfect words for every milestone, celebration, and heartfelt moment — from everyday occasions to seasonal holidays.
      </p>
    </div>
  </section>

  <!-- EVERYDAY GREETING CARDS -->
  <section id="everyday-greeting" class="py-20 bg-slate-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 fade-in">
        <span class="inline-block px-4 py-1 rounded-full bg-red-100 text-brand-red text-sm font-semibold mb-4">Everyday Occasions</span>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-900 mb-4">Everyday Greeting Cards</h2>
        <p class="text-slate-600 max-w-2xl mx-auto">
          Whether it's a birthday surprise or a note of encouragement, we carry cards for life's most meaningful everyday moments.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <article class="category-card bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl border border-slate-100 transition-all duration-300">
          <div class="img-zoom aspect-[16/10]">
            <img src="<%= siteImage('greeting-cards.birthday') %>" alt="Birthday greeting cards" class="w-full h-full object-cover" />
          </div>
          <div class="p-6">
            <h3 class="font-display font-bold text-xl text-slate-900 mb-2">Birthday</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Fun, heartfelt, and milestone birthday cards for all ages — from kids' parties to elegant adult celebrations.</p>
          </div>
        </article>

        <article class="category-card bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl border border-slate-100 transition-all duration-300">
          <div class="img-zoom aspect-[16/10]">
            <img src="<%= siteImage('greeting-cards.anniversary') %>" alt="Anniversary greeting cards" class="w-full h-full object-cover" />
          </div>
          <div class="p-6">
            <h3 class="font-display font-bold text-xl text-slate-900 mb-2">Anniversary</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Celebrate years of love with elegant anniversary cards for couples, parents, and dear friends.</p>
          </div>
        </article>

        <article class="category-card bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl border border-slate-100 transition-all duration-300">
          <div class="img-zoom aspect-[16/10]">
            <img src="<%= siteImage('greeting-cards.wedding') %>" alt="Wedding greeting cards" class="w-full h-full object-cover" />
          </div>
          <div class="p-6">
            <h3 class="font-display font-bold text-xl text-slate-900 mb-2">Wedding</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Beautiful cards to congratulate the happy couple on their special day, from classic to contemporary designs.</p>
          </div>
        </article>

        <article class="category-card bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl border border-slate-100 transition-all duration-300">
          <div class="img-zoom aspect-[16/10]">
            <img src="<%= siteImage('greeting-cards.baby') %>" alt="Baby greeting cards" class="w-full h-full object-cover" />
          </div>
          <div class="p-6">
            <h3 class="font-display font-bold text-xl text-slate-900 mb-2">Baby</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Welcome new arrivals with adorable baby shower, newborn, and gender-reveal greeting cards.</p>
          </div>
        </article>

        <article class="category-card bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl border border-slate-100 transition-all duration-300">
          <div class="img-zoom aspect-[16/10]">
            <img src="<%= siteImage('greeting-cards.sympathy') %>" alt="Sympathy greeting cards" class="w-full h-full object-cover" />
          </div>
          <div class="p-6">
            <h3 class="font-display font-bold text-xl text-slate-900 mb-2">Sympathy</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Thoughtful cards to express condolences, offer comfort, and share support during difficult times.</p>
          </div>
        </article>

        <article class="category-card bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl border border-slate-100 transition-all duration-300">
          <div class="img-zoom aspect-[16/10]">
            <img src="<%= siteImage('greeting-cards.graduation') %>" alt="Graduation greeting cards" class="w-full h-full object-cover" />
          </div>
          <div class="p-6">
            <h3 class="font-display font-bold text-xl text-slate-900 mb-2">Graduation</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Celebrate achievements with congratulatory cards for graduates of all levels — from kindergarten to college.</p>
          </div>
        </article>

        <article class="category-card bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl border border-slate-100 transition-all duration-300">
          <div class="img-zoom aspect-[16/10]">
            <img src="<%= siteImage('greeting-cards.thank-you') %>" alt="Thank You greeting cards" class="w-full h-full object-cover" />
          </div>
          <div class="p-6">
            <h3 class="font-display font-bold text-xl text-slate-900 mb-2">Thank You</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Express gratitude with cards that say thank you beautifully — perfect after gifts, favors, or kind gestures.</p>
          </div>
        </article>

        <article class="category-card bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl border border-slate-100 transition-all duration-300">
          <div class="img-zoom aspect-[16/10]">
            <img src="<%= siteImage('greeting-cards.get-well') %>" alt="Get Well greeting cards" class="w-full h-full object-cover" />
          </div>
          <div class="p-6">
            <h3 class="font-display font-bold text-xl text-slate-900 mb-2">Get Well</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Send warm wishes and encouragement with cheerful get well cards to brighten someone's recovery.</p>
          </div>
        </article>

        <article class="category-card bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl border border-slate-100 transition-all duration-300">
          <div class="img-zoom aspect-[16/10]">
            <img src="<%= siteImage('greeting-cards.congratulations') %>" alt="Congratulations greeting cards" class="w-full h-full object-cover" />
          </div>
          <div class="p-6">
            <h3 class="font-display font-bold text-xl text-slate-900 mb-2">Congratulations</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Celebrate promotions, new homes, engagements, and life's big wins with congratulatory greeting cards.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- SEASONAL HOLIDAY CARDS -->
  <section id="seasonal-holiday" class="py-20 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 fade-in">
        <span class="inline-block px-4 py-1 rounded-full bg-orange-100 text-brand-orange text-sm font-semibold mb-4">Seasonal &amp; Holidays</span>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-900 mb-4">Seasonal Holiday Cards</h2>
        <p class="text-slate-600 max-w-2xl mx-auto">
          Celebrate every season with our festive holiday card collection — from Christmas cheer to New Year's wishes.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <article class="category-card bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl border border-red-100 transition-all duration-300">
          <div class="img-zoom aspect-[16/10]">
            <img src="<%= siteImage('greeting-cards.christmas') %>" alt="Christmas holiday cards" class="w-full h-full object-cover" />
          </div>
          <div class="p-6">
            <h3 class="font-display font-bold text-xl text-brand-red mb-2">Christmas</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Classic and contemporary Christmas cards to spread holiday cheer to family and friends near and far.</p>
          </div>
        </article>

        <article class="category-card bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl border border-pink-100 transition-all duration-300">
