<%- include('partials/header', {
  title: 'Gifts & Balloons | Prabhu Cards & Gifts',
  description: 'Shop Willow Tree figurines, home décor, keepsakes, gift wrap, and colorful celebration balloons at Prabhu Cards & Gifts in Manorville, NY.',
  activePage: 'gifts-balloons'
}) %>

<main id="main-content" class="pt-24">
  <!-- PAGE HERO -->
  <section class="relative py-20 text-white">
    <div class="absolute inset-0">
      <img
        src="<%= siteImage('gifts-balloons.hero') %>"
        alt="Gifts and balloons at Prabhu Cards & Gifts"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 page-hero-gradient"></div>
    </div>
    <div class="relative container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-display text-4xl sm:text-5xl font-extrabold mb-4 fade-in">Gifts &amp; Balloons</h1>
      <p class="max-w-2xl mx-auto text-lg text-white/90 fade-in">
        Thoughtfully curated gifts and vibrant celebration balloons — everything you need to make every occasion unforgettable.
      </p>
    </div>
  </section>

  <!-- GIFTS GRID -->
  <section id="gifts" class="py-20 bg-slate-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 fade-in">
        <span class="inline-block px-4 py-1 rounded-full bg-blue-100 text-brand-blue text-sm font-semibold mb-4">Retail Gifts</span>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-900 mb-4">Gift Collection</h2>
        <p class="text-slate-600 max-w-2xl mx-auto">
          From meaningful figurines to practical keepsakes, discover gifts that show you care — plus bags and wrap to present them beautifully.
        </p>
      </div>

      <% const giftItems = [...inventory.willowTree, ...inventory.gifts]; %>
      <% if (giftItems.length) { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <% inventory.willowTree.forEach(function(item, index) { %>
            <article id="<%= index === 0 ? 'willow-tree' : '' %>" class="category-card bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl border border-slate-100 transition-all duration-300">
              <div class="img-zoom aspect-[4/3]">
                <img src="<%= item.image_url || 'https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=600&q=80' %>" alt="<%= item.name %>" class="w-full h-full object-cover" />
              </div>
              <div class="p-6">
                <span class="inline-block px-2 py-0.5 rounded-full bg-red-50 text-brand-red text-xs font-semibold mb-2">Willow Tree</span>
                <h3 class="font-display font-bold text-xl text-slate-900 mb-2"><%= item.name %></h3>
                <p class="text-slate-600 text-sm leading-relaxed"><%= item.description %></p>
              </div>
            </article>
          <% }); %>
          <% inventory.gifts.forEach(function(item) { %>
            <article class="category-card bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl border border-slate-100 transition-all duration-300">
              <div class="img-zoom aspect-[4/3]">
                <img src="<%= item.image_url || 'https://images.unsplash.com/photo-1549465220-1a0b9238b345a?w=600&q=80' %>" alt="<%= item.name %>" class="w-full h-full object-cover" />
              </div>
              <div class="p-6">
                <span class="inline-block px-2 py-0.5 rounded-full bg-blue-50 text-brand-blue text-xs font-semibold mb-2">Gifts</span>
                <h3 class="font-display font-bold text-xl text-slate-900 mb-2"><%= item.name %></h3>
                <p class="text-slate-600 text-sm leading-relaxed"><%= item.description %></p>
              </div>
            </article>
          <% }); %>
        </div>
      <% } else { %>
        <p class="text-center text-slate-500">Gift inventory is being updated. Visit us in-store to browse our full collection.</p>
      <% } %>
    </div>
  </section>

  <!-- VISIT STORE CTA -->
  <section class="py-12 bg-gradient-to-r from-blue-600 to-brand-blue text-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center fade-in">
      <h2 class="font-display text-2xl font-bold mb-3">Find the Perfect Gift In-Store</h2>
      <p class="text-white/90 max-w-xl mx-auto">Browse our gifts, balloons, and party supplies. Stop by today at 460 County Road 111, Suite 11.</p>
    </div>
  </section>

  <!-- BALLOONS SECTION -->
  <section id="balloons" class="py-20 balloon-section">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 fade-in">
        <span class="inline-block px-4 py-1 rounded-full bg-white text-brand-orange text-sm font-semibold mb-4 shadow-sm">Celebrations</span>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-900 mb-4">Balloons for Every Celebration</h2>
        <p class="text-slate-600 max-w-2xl mx-auto">
          Bright, colorful balloons to elevate birthdays, graduations, baby showers, and every special moment in between.
        </p>
      </div>

      <% const balloonBorderClasses = ['border-red-200', 'border-blue-200', 'border-pink-200', 'border-purple-200', 'border-green-200', 'border-orange-200']; %>
      <% const balloonTitleClasses = ['text-brand-red', 'text-brand-blue', 'text-pink-600', 'text-purple-600', 'text-green-600', 'text-brand-orange']; %>
      <% if (inventory.balloons.length) { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <% inventory.balloons.forEach(function(item, index) { %>
            <% const isFeatured = index === inventory.balloons.length - 1; %>
            <% if (isFeatured) { %>
              <article class="category-card bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl border-2 border-yellow-300 transition-all duration-300 sm:col-span-2 lg:col-span-3">
                <div class="grid md:grid-cols-2">
                  <div class="img-zoom aspect-[16/10] md:aspect-auto md:h-full min-h-[220px]">
                    <img src="<%= item.image_url || 'https://images.unsplash.com/photo-1530103862676-de8c9debad1d?w=800&q=80' %>" alt="<%= item.name %>" class="w-full h-full object-cover" />
                  </div>
                  <div class="p-8 flex flex-col justify-center bg-gradient-to-br from-yellow-50 via-orange-50 to-red-50">
                    <h3 class="font-display font-bold text-2xl sm:text-3xl text-slate-900 mb-3"><%= item.name %></h3>
                    <p class="text-slate-600 leading-relaxed mb-4"><%= item.description %></p>
                    <p class="inline-flex items-center gap-2 text-brand-orange font-bold text-lg">
                      <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      Custom multi-balloon arrangements are available directly in-store!
                    </p>
                  </div>
                </div>
              </article>
            <% } else { %>
              <article class="category-card bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl border-2 <%= balloonBorderClasses[index % balloonBorderClasses.length] %> transition-all duration-300">
                <div class="img-zoom aspect-[16/10]">
                  <img src="<%= item.image_url || 'https://images.unsplash.com/photo-1464349153735-7db50ed83c46?w=600&q=80' %>" alt="<%= item.name %>" class="w-full h-full object-cover" />
                </div>
                <div class="p-6">
                  <h3 class="font-display font-bold text-xl <%= balloonTitleClasses[index % balloonTitleClasses.length] %> mb-2"><%= item.name %></h3>
                  <p class="text-slate-600 text-sm leading-relaxed"><%= item.description %></p>
                </div>
              </article>
            <% } %>
          <% }); %>
        </div>
      <% } else { %>
        <p class="text-center text-slate-500">Balloon inventory is being updated. Visit us in-store for custom arrangements.</p>
      <% } %>
    </div>
  </section>

  <!-- PROMINENT IN-STORE NOTE -->
  <section class="py-16 bg-gradient-to-r from-brand-red via-brand-orange to-brand-blue">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center text-white fade-in">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-white/20 backdrop-blur-sm mb-6">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
          </svg>
        </div>
        <h2 class="font-display text-3xl sm:text-4xl font-extrabold mb-4">
          Custom Multi-Balloon Arrangements Are Available Directly In-Store!
        </h2>
        <p class="text-lg text-white/90 mb-8 leading-relaxed">
          Visit us at 460 County Road 111, Suite 11 in Manorville to browse our full gift selection and work with our team to design the perfect balloon arrangement for your celebration.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-2xl bg-white text-brand-red font-display font-bold shadow-xl hover:scale-105 transition-transform">
            Visit Our Store
          </a>
          <a href="tel:6313992808" class="inline-flex items-center gap-2 px-8 py-4 rounded-2xl border-2 border-white text-white font-semibold hover:bg-white/10 transition-colors">
            Call 631-399-2808
          </a>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
