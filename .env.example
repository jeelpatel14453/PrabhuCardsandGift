NODE_ENV=production
PORT=8080
SESSION_SECRET=replace-with-a-long-random-string
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=replace-with-a-strong-password

# SQLite on Render — mount a persistent disk, then point here
DATABASE_PATH=/var/data/prabhu.db

# Supabase Storage (server-side only). URL must be https://<project-ref>.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_your_service_key
SUPABASE_BUCKET=product-images
