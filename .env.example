NODE_ENV=production
PORT=8080
SESSION_SECRET=replace-with-a-long-random-string
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

# Supabase PostgreSQL — server-side only (Project Settings → Database → Connect)
# Use the URI connection string. Prefer the Session pooler or direct connection.
# Never expose DATABASE_URL to the browser.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-us-east-2.pooler.supabase.com:5432/postgres

# Supabase Storage (server-side only). URL must be https://<project-ref>.supabase.co
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=product-images
